function toPctX(pt) { return `${(pt / PAGE_WIDTH) * 100}%`; }
function toPctY(pt) { return `${(pt / PAGE_HEIGHT) * 100}%`; }
function toPctW(pt) { return `${(pt / PAGE_WIDTH) * 100}%`; }
function toPctH(pt) { return `${(pt / PAGE_HEIGHT) * 100}%`; }

function renderPreview() {
  const overlays = [...page1Overlays(), ...page2Overlays(), ...page3Overlays()];
  document.getElementById('previewPages').innerHTML = [1, 2, 3].map((page) => `
    <div class="sheet-page">
      <img src="${PAGE_IMAGES[page - 1]}" alt="Sheet page ${page}" />
      ${overlays.filter((entry) => entry.page === page && String(entry.text || '').trim() !== '').map((entry) => `
        <div class="overlay ${entry.cls} ${entry.align}${entry.box ? ' field-box' : ''}" style="left:${toPctX(entry.x)};top:${toPctY(entry.y)};width:${toPctW(entry.w)};height:${toPctH(entry.h)};">${escapeHtml(entry.text)}</div>
      `).join('')}
    </div>
  `).join('');
}

function renderAll() {
  renderSchoolCards();
  renderSpellSummary();
  renderSpellCards();
  renderDetails();
  renderWarband();
  renderSummary();
  renderPreview();
}

function exportData() {
  const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const anchor = document.createElement('a');
  anchor.href = url;
  anchor.download = 'frostgrave-character-data.json';
  anchor.click();
  URL.revokeObjectURL(url);
}

function importData(file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = () => {
    try {
      state = mergeState(defaultState(), JSON.parse(String(reader.result)));
      saveState();
      renderAll();
    } catch (error) {
      alert('That file does not look like valid Frostgrave character data.');
      console.error(error);
    }
  };
  reader.readAsText(file);
}

function resetAll() {
  if (!confirm('Clear all saved data from this browser?')) return;
  state = defaultState();
  saveState();
  renderAll();
}

function escapeHtml(value) {
  return String(value ?? '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;');
}

function handleDocumentInput(event) {
  const target = event.target;
  if (target.matches('[data-path]')) {
    setValue(target.dataset.path, target.value);
    if (target.dataset.path.startsWith('wizard.') || target.dataset.path === 'apprenticeCurrentHealth') {
      renderDetails();
    }
    renderSummary();
    renderPreview();
    if (target.dataset.path === 'treasury') renderWarband();
  }

  if (target.id === 'spellSearch') {
    state.spellSearch = target.value;
    saveState();
    renderSpellCards();
  }

  if (target.id === 'spellFilter') {
    state.spellFilter = target.value;
    saveState();
    renderSpellCards();
  }

  if (target.id === 'strictStarterMode') {
    state.strictStarterMode = target.checked;
    saveState();
    renderSpellSummary();
    renderSpellCards();
    renderSummary();
  }

  if (target.id === 'hasApprentice') {
    state.hasApprentice = target.checked;
    saveState();
    renderDetails();
    renderWarband();
    renderSummary();
    renderPreview();
  }

  if (target.matches('[data-soldier-index]')) {
    const index = Number(target.dataset.soldierIndex);
    state.soldierSlots[index].type = target.value;
    if (!target.value) {
      state.soldierSlots[index].items = '';
      state.soldierSlots[index].notes = '';
      state.soldierSlots[index].currentHealth = '';
    } else {
      state.soldierSlots[index].currentHealth = SOLDIER_MAP[target.value].health;
    }
    saveState();
    renderWarband();
    renderSummary();
    renderPreview();
  }
}

function handleDocumentClick(event) {
  const schoolButton = event.target.closest('[data-school]');
  if (schoolButton) {
    state.school = schoolButton.dataset.school;
    saveState();
    renderAll();
    return;
  }

  const spellToggle = event.target.closest('[data-spell-toggle]');
  if (spellToggle) {
    const spellName = spellToggle.dataset.spellToggle;
    const spell = SPELLS.find((entry) => entry.name === spellName);
    if (!spell) return;
    if (state.spells[spellName]) {
      state.spells[spellName] = false;
    } else {
      const eligibility = canSelectSpell(spell);
      if (!eligibility.ok) {
        alert(eligibility.reason);
        return;
      }
      state.spells[spellName] = true;
    }
    saveState();
    renderSpellSummary();
    renderSpellCards();
    renderSummary();
    renderPreview();
  }
}

function setupButtons() {
  document.getElementById('printBtn').addEventListener('click', () => window.print());
  document.getElementById('downloadDataBtn').addEventListener('click', exportData);
  document.getElementById('resetBtn').addEventListener('click', resetAll);
  document.getElementById('importDataInput').addEventListener('change', (event) => importData(event.target.files?.[0]));
  document.addEventListener('input', handleDocumentInput);
  document.addEventListener('change', handleDocumentInput);
  document.addEventListener('click', handleDocumentClick);
}

function setupInstallPrompt() {
  let deferredPrompt = null;
  const installBtn = document.getElementById('installBtn');

  window.addEventListener('beforeinstallprompt', (event) => {
    event.preventDefault();
    deferredPrompt = event;
    installBtn.hidden = false;
  });

  installBtn.addEventListener('click', async () => {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    await deferredPrompt.userChoice;
    deferredPrompt = null;
    installBtn.hidden = true;
  });

  window.addEventListener('appinstalled', () => {
    installBtn.hidden = true;
    deferredPrompt = null;
  });
}

async function registerServiceWorker() {
  if (!('serviceWorker' in navigator)) return;
  try {
    await navigator.serviceWorker.register('./sw.js');
  } catch (error) {
    console.warn('Service worker registration failed', error);
  }
}

renderAll();
setupButtons();
setupInstallPrompt();
registerServiceWorker();
