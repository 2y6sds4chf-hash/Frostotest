function clone(value) {
  return JSON.parse(JSON.stringify(value));
}

function defaultState() {
  return {
    wizardName: '',
    school: '',
    strictStarterMode: true,
    wizard: clone(STARTING_STATS.wizard),
    wizardItems: '',
    wizardNotes: '',
    hasApprentice: true,
    apprenticeName: '',
    apprenticeCurrentHealth: STARTING_STATS.apprentice.currentHealth,
    apprenticeItems: '',
    apprenticeNotes: '',
    homeBase: '',
    vault: '',
    treasury: '400',
    spells: Object.fromEntries(SPELLS.map((spell) => [spell.name, false])),
    spellSearch: '',
    spellFilter: 'starter',
    soldierSlots: Array.from({ length: 8 }, () => ({ type: '', items: '', notes: '', currentHealth: '' }))
  };
}

function mergeState(base, incoming) {
  if (Array.isArray(base) && Array.isArray(incoming)) {
    return base.map((entry, index) => mergeState(entry, incoming[index]));
  }
  if (base && typeof base === 'object' && incoming && typeof incoming === 'object' && !Array.isArray(base)) {
    const next = clone(base);
    for (const [key, value] of Object.entries(incoming)) {
      if (key in next) next[key] = mergeState(next[key], value);
    }
    return next;
  }
  return incoming === undefined ? base : incoming;
}

function loadState() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? mergeState(defaultState(), JSON.parse(raw)) : defaultState();
  } catch (error) {
    console.warn('Could not load saved state', error);
    return defaultState();
  }
}

let state = loadState();

function saveState() {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
}

function getValue(path) {
  return path.split('.').reduce((acc, key) => (acc == null ? undefined : acc[key]), state);
}

function setValue(path, value) {
  const keys = path.split('.');
  let cursor = state;
  for (let i = 0; i < keys.length - 1; i += 1) {
    const key = /^\d+$/.test(keys[i]) ? Number(keys[i]) : keys[i];
    cursor = cursor[key];
  }
  const last = /^\d+$/.test(keys[keys.length - 1]) ? Number(keys[keys.length - 1]) : keys[keys.length - 1];
  cursor[last] = value;
  saveState();
}

function relationFor(spellSchool, wizardSchool = state.school) {
  if (!wizardSchool || !SCHOOL_DATA[wizardSchool]) return 'unknown';
  if (spellSchool === wizardSchool) return 'own';
  if (SCHOOL_DATA[wizardSchool].aligned.includes(spellSchool)) return 'aligned';
  if (SCHOOL_DATA[wizardSchool].opposed === spellSchool) return 'opposed';
  return 'neutral';
}

function penaltyForRelation(relation) {
  return ({ own: 0, aligned: 2, neutral: 4, opposed: 6, unknown: 0 })[relation] ?? 0;
}

function adjustedCastingNumber(spell) {
  return spell.base + penaltyForRelation(relationFor(spell.school));
}

function selectedSpellNames() {
  return SPELLS.filter((spell) => state.spells[spell.name]).map((spell) => spell.name);
}

function starterSpellStats() {
  const alignedBySchool = {};
  const neutralBySchool = {};
  let own = 0;
  let opposed = 0;
  let total = 0;
  let alignedTotal = 0;
  let neutralTotal = 0;

  SPELLS.forEach((spell) => {
    if (!state.spells[spell.name]) return;
    total += 1;
    const relation = relationFor(spell.school);
    if (relation === 'own') own += 1;
    if (relation === 'aligned') {
      alignedTotal += 1;
      alignedBySchool[spell.school] = (alignedBySchool[spell.school] || 0) + 1;
    }
    if (relation === 'neutral') {
      neutralTotal += 1;
      neutralBySchool[spell.school] = (neutralBySchool[spell.school] || 0) + 1;
    }
    if (relation === 'opposed') opposed += 1;
  });

  return { own, total, opposed, alignedTotal, neutralTotal, alignedBySchool, neutralBySchool };
}

function starterSpellIssues() {
  if (!state.strictStarterMode) return [];
  if (!state.school) return ['Choose a school first so the spell rules can be enforced.'];

  const stats = starterSpellStats();
  const issues = [];

  if (stats.total !== 8) issues.push(`Choose exactly 8 starting spells. Current total: ${stats.total}.`);
  if (stats.own !== 3) issues.push(`Choose 3 spells from your own school. Current total: ${stats.own}.`);

  for (const aligned of SCHOOL_DATA[state.school].aligned) {
    const count = stats.alignedBySchool[aligned] || 0;
    if (count !== 1) issues.push(`Choose 1 spell from aligned school ${aligned}. Current total: ${count}.`);
  }

  const neutralSchoolsChosen = Object.values(stats.neutralBySchool).filter(Boolean).length;
  if (stats.neutralTotal !== 2 || neutralSchoolsChosen !== 2) {
    issues.push(`Choose 2 neutral spells from 2 different neutral schools. Current total: ${stats.neutralTotal}.`);
  }

  if (stats.opposed > 0) issues.push('Do not choose spells from the opposed school in starter mode.');

  return issues;
}

function canSelectSpell(spell) {
  if (!state.strictStarterMode) return { ok: true, reason: '' };
  if (!state.school) return { ok: false, reason: 'Pick a wizard school first.' };
  const relation = relationFor(spell.school);
  const stats = starterSpellStats();

  if (stats.total >= 8) return { ok: false, reason: 'Starter spellbook already has 8 spells.' };
  if (relation === 'opposed') return { ok: false, reason: 'Opposed school spells cannot be chosen at creation.' };
  if (relation === 'own' && stats.own >= 3) return { ok: false, reason: 'You already have 3 spells from your own school.' };
  if (relation === 'aligned' && (stats.alignedBySchool[spell.school] || 0) >= 1) {
    return { ok: false, reason: `You already chose a spell from ${spell.school}.` };
  }
  if (relation === 'neutral' && stats.neutralTotal >= 2) return { ok: false, reason: 'Starter builds only take 2 neutral spells.' };
  if (relation === 'neutral' && (stats.neutralBySchool[spell.school] || 0) >= 1) {
    return { ok: false, reason: 'Neutral starter spells must come from different schools.' };
  }
  return { ok: true, reason: '' };
}

function apprenticeStats() {
  const wizardFight = parseSignedInt(state.wizard.fight, 2);
  const wizardShoot = parseSignedInt(state.wizard.shoot, 0);
  const wizardWill = parseSignedInt(state.wizard.will, 4);
  const wizardHealth = parseIntSafe(state.wizard.health, 14);
  return {
    move: String(parseIntSafe(state.wizard.move, 6)),
    fight: formatSigned(wizardFight - 2),
    shoot: formatSigned(wizardShoot),
    armour: '10',
    will: formatSigned(wizardWill - 2),
    health: String(wizardHealth - 2),
    currentHealth: state.apprenticeCurrentHealth || String(wizardHealth - 2)
  };
}

function parseIntSafe(value, fallback = 0) {
  const parsed = Number.parseInt(String(value).replace(/[^0-9-]/g, ''), 10);
  return Number.isFinite(parsed) ? parsed : fallback;
}

function parseSignedInt(value, fallback = 0) {
  const parsed = Number.parseInt(String(value).replace(/[^0-9+-]/g, ''), 10);
  return Number.isFinite(parsed) ? parsed : fallback;
}

function formatSigned(value) {
  return `${value >= 0 ? '+' : ''}${value}`;
}

function rosterSlots() {
  return state.soldierSlots.map((slot) => {
    const template = SOLDIER_MAP[slot.type] || null;
    return {
      ...slot,
      cost: template?.cost ?? 0,
      specialist: template?.specialist ?? false,
      move: template?.move ?? '',
      fight: template?.fight ?? '',
      shoot: template?.shoot ?? '',
      armour: template?.armour ?? '',
      will: template?.will ?? '',
      health: template?.health ?? '',
      currentHealth: slot.currentHealth || template?.health || '',
      notesFull: [template?.notes || '', slot.notes || ''].filter(Boolean).join('\n')
    };
  });
}

function warbandSummary() {
  const roster = rosterSlots().filter((slot) => slot.type);
  const apprenticeCost = state.hasApprentice ? 100 : 0;
  const soldierCost = roster.reduce((sum, slot) => sum + slot.cost, 0);
  const specialistCount = roster.filter((slot) => slot.specialist).length;
  const totalCost = apprenticeCost + soldierCost;
  return {
    soldierCount: roster.length,
    specialistCount,
    apprenticeCost,
    soldierCost,
    totalCost,
    goldRemaining: parseIntSafe(state.treasury || '400', 400) - totalCost,
    issues: [
      roster.length > 8 ? 'You can only take up to 8 soldiers.' : '',
      specialistCount > 4 ? 'Starter warbands can include at most 4 specialists.' : '',
      totalCost > parseIntSafe(state.treasury || '400', 400) ? 'Your warband currently costs more gold than you have available.' : ''
    ].filter(Boolean)
  };
}

