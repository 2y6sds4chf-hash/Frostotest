        <div><strong>Specialists</strong><span>${warband.specialistCount}</span></div>
      </div>
      ${schoolInfo ? `<div class="mini-rule"><strong>Aligned:</strong> ${schoolInfo.aligned.join(', ')}</div><div class="mini-rule"><strong>Opposed:</strong> ${schoolInfo.opposed}</div>` : '<div class="mini-rule">Choose a school to unlock school relations and starter casting numbers.</div>'}
    </section>

    <section class="panel stack">
      <h3>Progress</h3>
      <ul class="checklist">
        ${checklist.map((item) => `<li class="${item.done ? 'done' : ''}">${item.done ? '✓' : '•'} ${item.label}</li>`).join('')}
      </ul>
    </section>
  `;
}

function overlay({ text, x, y, w, h, page, cls = 'normal', box = false, align = 'left' }) {
  return { text, x, y, w, h, page, cls, box, align };
}

